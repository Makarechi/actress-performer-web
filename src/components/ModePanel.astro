---
import { localizedPath, type Locale } from "@data/i18n";
import { stageCopy } from "@data/stage";

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const copy = stageCopy[locale];
---

<section class="section mode-panel" aria-label={copy.current.eyebrow}>
  <div class="section-heading">
    <p class="eyebrow">{copy.current.eyebrow}</p>
    <h2>{copy.current.title}</h2>
    <p>{copy.current.body}</p>
  </div>
  <div class="mode-grid">
    {
      copy.modes.map(([title, body], index) => (
        <article>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))
    }
  </div>
  <div class="mode-actions">
    <a class="button primary" href={localizedPath(locale, "stage/")}>{copy.eyebrow}</a>
    <a class="button secondary" href={localizedPath(locale, "casting/")}>{copy.enterCasting}</a>
  </div>
</section>
