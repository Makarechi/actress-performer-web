---
import InstagramCard from "@components/InstagramCard.astro";
import MediaPlaceholder from "@components/MediaPlaceholder.astro";
import { getLocalizedInstagramPosts, localizedPath, translations, type Locale } from "@data/i18n";
import { localeVisuals } from "@data/localeVisuals";
import { profile } from "@data/profile";
import { stageCopy } from "@data/stage";

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const t = translations[locale];
const copy = stageCopy[locale];
const visual = localeVisuals[locale];
const posts = getLocalizedInstagramPosts(locale);
const stagePosts = posts.filter((post) =>
  ["nemocnica-tvjoj", "vocal-concert", "voice-training", "hosting-st-nicholas"].includes(post.id)
);
---

<main class:list={["stage-experience", `stage-${visual.theme}`]}>
  <section class="stage-hero" data-stage-theme={visual.theme}>
    <canvas
      data-stage-hero-canvas
      data-theme={visual.theme}
      data-languages={JSON.stringify(t.languageRows.map(([name, level, uses]) => ({ name, level, uses })))}
      aria-hidden="true"
    ></canvas>
    <div class="stage-hero-copy">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1>{copy.headline}</h1>
      <p>{copy.body}</p>
      <div class="hero-actions">
        <a class="button primary" href={localizedPath(locale, "casting/")}>{copy.enterCasting}</a>
        <a class="button secondary" href={localizedPath(locale)}>{copy.backToHub}</a>
      </div>
    </div>
    <div class="stage-portrait">
      <img src={profile.headshot} alt={`Portrait of ${profile.name}`} width="1080" height="1080" />
      <span>{profile.name}</span>
    </div>
  </section>

  <section class="section locale-visual-plan">
    <div class="section-heading">
      <p class="eyebrow">{visual.eyebrow}</p>
      <h2>{visual.title}</h2>
      <p>{visual.body}</p>
    </div>
    <div class="visual-plan-layout">
      <article class="visual-backdrop-card">
        <p class="eyebrow">Hero backdrop</p>
        <h3>{visual.backdrop}</h3>
      </article>
      <div class="visual-media-list">
        {
          visual.media.map((item) => (
            <article>
              <span></span>
              <p>{item}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section stage-mode-map">
    <div class="section-heading">
      <p class="eyebrow">{copy.current.eyebrow}</p>
      <h2>{copy.current.title}</h2>
      <p>{copy.current.body}</p>
    </div>
    <div class="mode-grid">
      {
        copy.modes.map(([title, body], index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{title}</h3>
            <p>{body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section stage-moments">
    <div class="section-heading">
      <p class="eyebrow">Creative tech plan</p>
      <h2>Scene chapters for future media.</h2>
    </div>
    <div class="stage-moment-grid">
      {
        copy.moments.map(([title, body]) => (
          <article>
            <h3>{title}</h3>
            <p>{body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section dark-band">
    <div class="section-heading">
      <p class="eyebrow">{t.selected.eyebrow}</p>
      <h2>{t.selected.title}</h2>
      <p>{t.selected.body}</p>
    </div>
    <div class="instagram-grid featured">
      {stagePosts.map((post) => <InstagramCard {...post} />)}
    </div>
  </section>

  <section class="section split-media">
    <div class="section-heading">
      <p class="eyebrow">Voice & music experience</p>
      <h2>{t.voice.title}</h2>
      <p>{t.voice.body}</p>
    </div>
    <div class="media-grid">
      <MediaPlaceholder title="Audio-reactive voice scene" category="planned stage media" note={t.voice.sampleSet} />
      <MediaPlaceholder title="Piano light scene" category="planned stage media" note={t.music.piano} />
    </div>
  </section>
</main>

<script>
  document.querySelectorAll("[data-stage-hero-canvas]").forEach((canvas) => {
    if (!(canvas instanceof HTMLCanvasElement)) return;

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const languages = JSON.parse(canvas.dataset.languages ?? "[]");
    const theme = canvas.dataset.theme || "constellation";
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let frame = 0;
    let raf = 0;
    let pointer = { x: 0.5, y: 0.5 };

    function resize() {
      const rect = canvas.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.max(1, Math.floor(rect.width * dpr));
      canvas.height = Math.max(1, Math.floor(rect.height * dpr));
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function draw() {
      const width = canvas.clientWidth;
      const height = canvas.clientHeight;
      frame += reducedMotion ? 0 : 0.01;

      ctx.clearRect(0, 0, width, height);
      ctx.fillStyle = "#100f0e";
      ctx.fillRect(0, 0, width, height);

      const palettes = {
        constellation: ["rgba(47, 143, 134, 0.34)", "rgba(143, 36, 60, 0.18)", "rgba(16, 15, 14, 0.96)"],
        mountains: ["rgba(92, 124, 118, 0.4)", "rgba(185, 133, 59, 0.14)", "rgba(14, 22, 22, 0.98)"],
        amber: ["rgba(219, 161, 72, 0.4)", "rgba(122, 54, 34, 0.28)", "rgba(20, 14, 12, 0.98)"],
        opera: ["rgba(204, 175, 105, 0.38)", "rgba(128, 21, 42, 0.3)", "rgba(12, 10, 10, 0.98)"],
        sunflower: ["rgba(244, 194, 77, 0.38)", "rgba(40, 87, 154, 0.28)", "rgba(10, 18, 30, 0.98)"],
        velvet: ["rgba(143, 36, 60, 0.42)", "rgba(83, 19, 34, 0.28)", "rgba(12, 8, 9, 0.98)"]
      };
      const palette = palettes[theme] || palettes.constellation;
      const bg = ctx.createRadialGradient(width * pointer.x, height * pointer.y, 20, width * 0.52, height * 0.42, Math.max(width, height));
      bg.addColorStop(0, palette[0]);
      bg.addColorStop(0.38, palette[1]);
      bg.addColorStop(1, palette[2]);
      ctx.fillStyle = bg;
      ctx.fillRect(0, 0, width, height);

      if (theme === "mountains") {
        for (let range = 0; range < 3; range += 1) {
          ctx.fillStyle = `rgba(255, 253, 248, ${0.08 + range * 0.045})`;
          ctx.beginPath();
          ctx.moveTo(0, height);
          for (let i = 0; i <= 8; i += 1) {
            const x = (width / 8) * i;
            const y = height * (0.52 + range * 0.11) - Math.sin(i * 1.6 + range) * 70;
            ctx.lineTo(x, y);
          }
          ctx.lineTo(width, height);
          ctx.closePath();
          ctx.fill();
        }
      }

      if (theme === "sunflower") {
        ctx.strokeStyle = "rgba(244, 194, 77, 0.18)";
        for (let i = 0; i < 36; i += 1) {
          const angle = i * ((Math.PI * 2) / 36) + frame * 0.2;
          ctx.beginPath();
          ctx.moveTo(width * 0.68, height * 0.5);
          ctx.lineTo(width * 0.68 + Math.cos(angle) * width, height * 0.5 + Math.sin(angle) * width);
          ctx.stroke();
        }
      }

      if (theme === "velvet" || theme === "opera") {
        for (let i = 0; i < 7; i += 1) {
          const x = (width / 6) * i + Math.sin(frame + i) * 16;
          const curtain = ctx.createLinearGradient(x - 80, 0, x + 80, 0);
          curtain.addColorStop(0, "rgba(0,0,0,0)");
          curtain.addColorStop(0.5, theme === "opera" ? "rgba(185,133,59,0.14)" : "rgba(143,36,60,0.22)");
          curtain.addColorStop(1, "rgba(0,0,0,0)");
          ctx.fillStyle = curtain;
          ctx.fillRect(x - 120, 0, 240, height);
        }
      }

      if (theme === "amber") {
        ctx.strokeStyle = "rgba(219, 161, 72, 0.18)";
        ctx.lineWidth = 1;
        for (let i = 0; i < 10; i += 1) {
          ctx.beginPath();
          ctx.moveTo(0, height * (0.18 + i * 0.08));
          ctx.bezierCurveTo(width * 0.35, height * (0.05 + i * 0.08), width * 0.7, height * (0.3 + i * 0.06), width, height * (0.12 + i * 0.08));
          ctx.stroke();
        }
      }

      for (let i = 0; i < 5; i += 1) {
        const x = width * (0.12 + i * 0.18) + Math.sin(frame + i) * 24;
        const cone = ctx.createLinearGradient(x, 0, width * 0.5, height);
        cone.addColorStop(0, "rgba(255, 253, 248, 0.16)");
        cone.addColorStop(1, "rgba(255, 253, 248, 0)");
        ctx.fillStyle = cone;
        ctx.beginPath();
        ctx.moveTo(x, 0);
        ctx.lineTo(x + 160, height);
        ctx.lineTo(x - 160, height);
        ctx.closePath();
        ctx.fill();
      }

      const centerX = width * 0.66;
      const centerY = height * 0.52;
      languages.forEach((language, index) => {
        const angle = frame + index * ((Math.PI * 2) / Math.max(languages.length, 1));
        const radius = Math.min(width, height) * (0.22 + (index % 2) * 0.06);
        const x = centerX + Math.cos(angle) * radius;
        const y = centerY + Math.sin(angle) * radius * 0.62;
        const hue = index % 3 === 0 ? "#b9853b" : index % 3 === 1 ? "#8f243c" : "#2f8f86";

        ctx.strokeStyle = "rgba(255, 253, 248, 0.16)";
        ctx.beginPath();
        ctx.moveTo(centerX, centerY);
        ctx.lineTo(x, y);
        ctx.stroke();

        ctx.fillStyle = hue;
        ctx.beginPath();
        ctx.arc(x, y, 6, 0, Math.PI * 2);
        ctx.fill();

        ctx.fillStyle = "rgba(255, 253, 248, 0.86)";
        ctx.font = "700 13px Inter, system-ui, sans-serif";
        ctx.fillText(language.name, x + 12, y + 4);
      });

      if (!reducedMotion) raf = window.requestAnimationFrame(draw);
    }

    resize();
    draw();

    canvas.addEventListener("pointermove", (event) => {
      const rect = canvas.getBoundingClientRect();
      pointer = {
        x: (event.clientX - rect.left) / rect.width,
        y: (event.clientY - rect.top) / rect.height
      };
      if (reducedMotion) draw();
    });

    window.addEventListener("resize", () => {
      resize();
      draw();
    });

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) window.cancelAnimationFrame(raf);
      if (!document.hidden && !reducedMotion) draw();
    });
  });
</script>
