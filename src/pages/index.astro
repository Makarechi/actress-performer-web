---
import "../styles/global.css";
import { localeNames, locales } from "@data/i18n";
import { withBase } from "@data/paths";
import { profile } from "@data/profile";

const base = import.meta.env.BASE_URL ?? "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, follow" />
    <title>{profile.name} — Choose Language</title>
    <meta http-equiv="refresh" content={`2; url=${withBase("/en/")}`} />
    <script define:vars={{ base }}>
      const supported = ["en", "sk", "pl", "it", "uk", "ru"];
      const normalizedBase = base.endsWith("/") ? base : `${base}/`;
      const stored = window.localStorage.getItem("preferredLocale");
      const browserLocale = (navigator.languages || [navigator.language || "en"])
        .map((item) => item.slice(0, 2).toLowerCase())
        .find((item) => supported.includes(item));
      const target = supported.includes(stored) ? stored : browserLocale || "en";
      window.location.replace(`${normalizedBase}${target}/`);
    </script>
  </head>
  <body>
    <main class="language-gate">
      <h1>{profile.name}</h1>
      <p>Choose a language</p>
      <div>
        {locales.map((locale) => <a href={withBase(`/${locale}/`)}>{localeNames[locale]}</a>)}
      </div>
    </main>
  </body>
</html>
